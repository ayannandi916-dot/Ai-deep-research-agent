{
  "name": "research-agent",
  "version": "0.1.0",
  "description": "AI research agent with X-402 micro-payment support",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",

    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",

    "hardhat:node": "hardhat node",
    "hardhat:deploy": "hardhat run scripts/deploy-mock.ts --network hardhat",
    "hardhat:fund": "hardhat run scripts/fund-wallet.ts --network hardhat",
    "hardhat:deploy:sepolia": "hardhat run scripts/deploy-mock.ts --network baseSepolia",

    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",

    "frontend:dev": "cd frontend && next dev",
    "frontend:build": "cd frontend && next build",
    "frontend:start": "cd frontend && next start"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.19.2",
    "hardhat": "^2.22.4",
    "nanoid": "^5.0.7",
    "pg": "^8.11.5",
    "viem": "^2.13.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@vitest/coverage-v8": "^1.6.0",
    "drizzle-kit": "^0.21.4",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}